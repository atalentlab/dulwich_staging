# Dulwich API Configuration
REACT_APP_API_URL=https://www.dulwich.atalent.xyz


# Site URL — used for absolute og:image URLs in public/index.html
# Dev: points to Express server (run: node server.js in a separate terminal)
REACT_APP_SITE_URL=http://localhost:4000

# Default locale
REACT_APP_DEFAULT_LOCALE=zh

HOST=0.0.0.0
DANGEROUSLY_DISABLE_HOST_CHECK=true